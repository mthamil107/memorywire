{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memwire.dev/schemas/v0/types/procedural",
  "title": "AMP procedural memory record",
  "description": "A stored procedural memory: a how-to procedure encoded as a pytransitions-compatible FSM (spec section 7).",
  "type": "object",
  "required": ["id", "agent_id", "type", "content", "created_at"],
  "properties": {
    "id":         { "type": "string", "minLength": 1 },
    "agent_id":   { "type": "string", "minLength": 1, "maxLength": 256 },
    "user_id":    { "type": "string", "maxLength": 256 },
    "type":       { "const": "procedural" },
    "content":    {
      "type": "object",
      "description": "FSM definition per spec section 7 (pytransitions-compatible).",
      "required": ["name", "initial", "states", "transitions", "current"],
      "properties": {
        "name":    { "type": "string", "minLength": 1 },
        "initial": { "type": "string", "minLength": 1 },
        "states":  {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["trigger", "source", "dest"],
            "properties": {
              "trigger": { "type": "string", "minLength": 1 },
              "source":  { "type": "string", "minLength": 1 },
              "dest":    { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        },
        "current": { "type": "string", "minLength": 1 },
        "metadata": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "metadata":   { "type": "object", "additionalProperties": true },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0 },
    "source":     { "type": "string" },
    "created_at": { "type": "integer", "description": "Unix epoch ms" },
    "updated_at": { "type": "integer", "description": "Unix epoch ms" },
    "expires_at": { "type": ["integer", "null"], "description": "Unix epoch ms; optional TTL" }
  },
  "additionalProperties": true
}
