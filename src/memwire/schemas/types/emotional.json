{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memwire.dev/schemas/v0/types/emotional",
  "title": "AMP emotional memory record",
  "description": "A stored emotional memory: affective association with an experience (sentiment/affect).",
  "type": "object",
  "required": ["id", "agent_id", "type", "content", "created_at"],
  "properties": {
    "id":         { "type": "string", "minLength": 1 },
    "agent_id":   { "type": "string", "minLength": 1, "maxLength": 256 },
    "user_id":    { "type": "string", "maxLength": 256 },
    "type":       { "const": "emotional" },
    "content":    { "type": "string", "minLength": 1 },
    "metadata":   { "type": "object", "additionalProperties": true },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0 },
    "source":     { "type": "string" },
    "created_at": { "type": "integer", "description": "Unix epoch ms" },
    "updated_at": { "type": "integer", "description": "Unix epoch ms" },
    "expires_at": { "type": ["integer", "null"], "description": "Unix epoch ms; optional TTL" },
    "sentiment": {
      "type": "string",
      "description": "Coarse polarity label.",
      "enum": ["positive", "negative", "neutral", "mixed"]
    },
    "valence": {
      "type": "number",
      "description": "Signed affective valence in [-1, 1] (negative = unpleasant, positive = pleasant).",
      "minimum": -1,
      "maximum": 1
    },
    "arousal": {
      "type": "number",
      "description": "Affective arousal in [0, 1] (0 = calm, 1 = highly activated).",
      "minimum": 0,
      "maximum": 1
    },
    "emotion": {
      "type": "string",
      "description": "Optional discrete-emotion label (e.g. 'joy', 'anger', 'fear', 'sadness', 'anxiety')."
    },
    "target": {
      "type": "string",
      "description": "Identifier of the entity, topic, or experience the affect is associated with."
    }
  },
  "additionalProperties": true
}
