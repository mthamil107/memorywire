{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memwire.dev/schemas/v0/operations/forget",
  "title": "AMP forget request",
  "description": "Request payload for the forget operation that deletes memories matching a filter.",
  "type": "object",
  "required": ["agent_id"],
  "properties": {
    "agent_id":   { "type": "string" },
    "user_id":    { "type": "string" },
    "ids":        { "type": "array", "items": { "type": "string" } },
    "filter":     { "type": "object", "additionalProperties": true },
    "hard_delete": { "type": "boolean", "default": false },
    "reason":     { "type": "string" }
  }
}
